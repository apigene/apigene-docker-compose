# =============================================================================
# Apigene — environment configuration
# =============================================================================
#
#   cp .env.example .env
#   Add your API keys and secrets, then run: ./apigene setup
#
# Open Apigene at http://localhost (or your chosen APIGENE_PORT).
# Set NEXT_PUBLIC_SERVER_BASE_URL and ALLOWED_ORIGINS to that same URL.
#
# MongoDB and Redis are included in this stack. Connection settings for those
# services are applied automatically — you usually do not need to change MONGO_DB_URL
# or REDIS_* unless you use external databases.
# =============================================================================

# -----------------------------------------------------------------------------
# Public URLs
# -----------------------------------------------------------------------------

# Base URL of your Apigene deployment (what users type in the browser).
NEXT_PUBLIC_SERVER_BASE_URL=http://localhost

# Comma-separated list of origins allowed to call the API (CORS).
# Must include your Apigene URL (same host and port as above).
ALLOWED_ORIGINS=http://localhost

# Host port for the web gateway (default 80). On Linux, port 80 may require sudo.
# If you change this, update NEXT_PUBLIC_SERVER_BASE_URL and ALLOWED_ORIGINS too.
# APIGENE_PORT=8080

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Logical environment name — use a unique value per deployment to isolate data.
DATABASE_ENV=local

# Optional tenant identifier (defaults to "local" in docker-compose.yml).
# TENANT_NAME=local

# Host port for MongoDB (default 27017). Change if you already run MongoDB locally.
# MONGO_HOST_PORT=27018

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# local — readable logs in the console (recommended for development).
# cloud — structured logs for production log aggregation.
LOG_ENV=local

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

# Required. Powers embeddings, AI features, and default language models.
OPENAI_API_KEY=

# OpenAI API key used by the web app when no user-specific model is set.
# Usually the same as OPENAI_API_KEY.
DEFAULT_OPEN_API_KEY=

# -----------------------------------------------------------------------------
# Clerk (authentication)
# Get keys from https://dashboard.clerk.com
# See README.md for full Clerk setup instructions.
# -----------------------------------------------------------------------------

# Required. Public key used to verify signed-in users (PEM, or base64:… prefix).
AUTH_CLERK_PUBLIC_KEY=

# Required. Secret key from the Clerk dashboard.
CLERK_SECRET_KEY=

# Required. Publishable key from the Clerk dashboard (starts with pk_).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Required. Clerk Frontend API URL (e.g. https://your-app.clerk.accounts.dev).
# Find it in Clerk Dashboard → API Keys → Advanced.
CLERK_REMOTE_API_URL=

# Required. Name of your Clerk JWT template for Apigene API access.
NEXT_PUBLIC_AUTH_CLERK_JWT_TPL=

# Recommended. Secret for validating Clerk webhooks (organization sync).
CLERK_WEBHOOK_SECRET=

# Paths for sign-in and sign-up pages in the web app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------------------------
# Cache and background jobs
# -----------------------------------------------------------------------------

CACHE_ENABLED=True

# -----------------------------------------------------------------------------
# Features
# -----------------------------------------------------------------------------

# true — enable interactive UI actions in MCP agent workflows.
APIGENE_FEATURE_MCP_APP=true

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------

DATADOG_API_KEY=
DD_TRACE_ENABLED=false

# -----------------------------------------------------------------------------
# Image version (optional)
# -----------------------------------------------------------------------------

# Tag for all public.ecr.aws/apigene/* images (default: latest).
# APIGENE_IMAGE_TAG=latest
